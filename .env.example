# CardTrade 環境變數設定
# 複製此檔案為 .env 並填入實際值

# Google Gemini API Key（用於卡片圖片識別）
# 免費申請：https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT 密鑰（用戶登入認證）
# 可用以下指令生成：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_here

# 資料庫設定（SQLite）
DATABASE_URL=sqlite:///./cardtrade.db

# 伺服器設定
HOST=0.0.0.0
PORT=8000

# 前端網址（用於 CORS）
FRONTEND_URL=http://localhost:5173

# 上傳設定
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads
